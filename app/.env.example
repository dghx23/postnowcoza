# Postgres connection string (audit log + metadata)
DATABASE_URL="postgresql://user:password@localhost:5432/postnow"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-hex-32"
NEXTAUTH_URL="http://localhost:3000"

# S3-compatible object storage for uploaded documents
S3_REGION="af-south-1"
S3_ENDPOINT=""
S3_BUCKET="postnow-documents"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Bob Go (bobgo.co.za) courier API - dispatch and managed returns
BOBGO_BASE_URL="https://api.sandbox.bobgo.co.za/v2"
BOBGO_API_TOKEN=""
# Generated under Account settings -> Webhook subscriptions -> Webhook secret
BOBGO_WEBHOOK_SECRET=""

# Our print/dispatch facility address - collection point for outbound
# shipments, delivery point for returns
FACILITY_STREET_ADDRESS=""
FACILITY_LOCAL_AREA=""
FACILITY_CITY=""
FACILITY_ZONE=""
FACILITY_POSTAL_CODE=""
FACILITY_CONTACT_NAME="PostNow Dispatch"
FACILITY_CONTACT_EMAIL=""
FACILITY_CONTACT_PHONE=""

# Bob Pay (bobpay.co.za) payments API - dispatch fee collection
BOBPAY_BASE_URL="https://api.sandbox.bobpay.co.za"
# JWT from POST /login, expires after 30 days - needs manual/scheduled renewal
BOBPAY_API_TOKEN=""
# Account passphrase, used to verify the `signature` field on incoming webhooks
BOBPAY_PASSPHRASE=""

# Epson Connect - one-click print queue printing (unverified integration,
# see app/src/lib/epson.ts - confirm against https://developer.epsonconnect.com/
# before relying on this in production)
EPSON_CLIENT_ID=""
EPSON_CLIENT_SECRET=""
EPSON_REDIRECT_URI="https://app.postnow.co.za/api/epson/callback"
# Optional: only needed if Epson Connect requires an API key header
EPSON_API_KEY=""
# Optional overrides if Epson's documented base URLs differ from the defaults
EPSON_AUTH_BASE_URL=""
EPSON_API_BASE_URL=""
