# Postgres connection string (audit log + metadata)
DATABASE_URL="postgresql://user:password@localhost:5432/postnow"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-hex-32"
NEXTAUTH_URL="http://localhost:3000"

# S3-compatible object storage for uploaded documents (Cloudflare R2)
# S3_REGION must be the literal string "auto" for R2 - any other value
# breaks the SigV4 request signature (R2 rejects it with
# SignatureDoesNotMatch, not a scoping/latency issue like on real AWS S3).
S3_REGION="auto"
S3_ENDPOINT=""
S3_BUCKET="postnow-documents"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Bob Go (bobgo.co.za) courier API - dispatch and managed returns
BOBGO_BASE_URL="https://api.sandbox.bobgo.co.za/v2"
BOBGO_API_TOKEN=""
# Generated under Account settings -> Webhook subscriptions -> Webhook secret
BOBGO_WEBHOOK_SECRET=""

# Our print/dispatch facility address - collection point for outbound
# shipments, delivery point for returns
FACILITY_STREET_ADDRESS=""
FACILITY_LOCAL_AREA=""
FACILITY_CITY=""
FACILITY_ZONE=""
FACILITY_POSTAL_CODE=""
FACILITY_CONTACT_NAME="PostNow Dispatch"
FACILITY_CONTACT_EMAIL=""
FACILITY_CONTACT_PHONE=""

# Bob Pay (bobpay.co.za) — legacy; app now uses PayFast for customer checkout
BOBPAY_BASE_URL="https://api.sandbox.bobpay.co.za"
BOBPAY_API_TOKEN=""
BOBPAY_PASSPHRASE=""

# PayFast (payfast.co.za) — customer dispatch fee checkout
# Vercel: Merchant_ID_Payfast + Merchant_Key_Payfast (aliases PAYFAST_* also work)
Merchant_ID_Payfast=""
Merchant_Key_Payfast=""
# Optional passphrase from PayFast dashboard (Settings → Security)
PAYFAST_PASSPHRASE=""
# Set true only when using sandbox.payfast.co.za test credentials
PAYFAST_SANDBOX="false"
# Fee charged at upload when no courier rate has been booked yet (ZAR)
DEFAULT_DISPATCH_FEE="149"

# Epson Connect API v2 — one-click print queue printing
# Register an app at https://developer.epsonconnect.com/ and paste credentials
# carefully (no trailing spaces — they cause invalid_client).
# Token endpoint requires HTTP Basic (client_id:client_secret); see app/src/lib/epson.ts
# and https://developer.epsonconnect.com/Portals/tutorial
EPSON_CLIENT_ID=""
EPSON_CLIENT_SECRET=""
# Must exactly match the Redirect URI registered on the Epson app
EPSON_REDIRECT_URI="https://app.postnow.co.za/api/epson/callback"
# Required on every printing/* call alongside the Bearer device token
EPSON_API_KEY=""
# Optional overrides (defaults: auth.epsonconnect.com / api.epsonconnect.com/api/2)
EPSON_AUTH_BASE_URL=""
EPSON_API_BASE_URL=""

# SMTP - only needed for the "Epson Direct" printing method (Epson's Email
# Print feature: attaching a PDF to a plain email sent to the printer's own
# assigned address prints it, no OAuth app registration needed). Sends from
# the dedicated postnowprint.agent@postnow.co.za mailbox on Zoho Mail. The
# printer's own Email Print address itself is configured in-app on
# /printer, not here (see src/lib/emailPrint.ts).
SMTP_HOST="smtppro.zoho.com"
SMTP_PORT="587"
# Login for the postnowprint.agent@postnow.co.za mailbox
Zoho_PrintAgent_User=""
# Same password Zoho uses for IMAP/POP/SMTP on that mailbox
SMTP_PASSWORD=""
# Optional; defaults to Zoho_PrintAgent_User if unset
SMTP_FROM_EMAIL=""
# Incoming mail (read Epson owner-notifications from the same mailbox —
# see src/lib/zohoMailbox.ts). Tries IMAP first, then POP3.
IMAP_HOST="imappro.zoho.com"
IMAP_PORT="993"
POP_HOST="poppro.zoho.com"
POP_PORT="995"
# Optional: Zoho Application-Specific Password for IMAP/POP when TFA/SAML
# blocks the normal login password (SMTP can still use SMTP_PASSWORD).
IMAP_PASSWORD=""
# Optional: authorize GET/POST /api/epson/notifications/sync for Vercel Cron
# (Authorization: Bearer <CRON_SECRET>). Staff session also works.
CRON_SECRET=""

# The Courier Guy direct API (api.portal.thecourierguy.co.za, Shiplogic-based)
# - dashboard quote tool only, not used for actual dispatch (see
# app/src/lib/courierguy.ts)
COURIER_GUY_API=""
# Optional override; defaults to production (https://api.portal.thecourierguy.co.za)
COURIER_GUY_BASE_URL=""

# xAI / Grok Voice Agent (in-app at /voice)
# Server-only API key — used to mint short-lived ephemeral client secrets for
# the browser WebSocket. Never expose this to the client.
# Get a key at https://console.x.ai
XAI_API_KEY=""
# Optional; defaults to grok-voice-latest
XAI_VOICE_MODEL="grok-voice-latest"
