generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  STAFF
  ADMIN
}

enum DocumentStatus {
  UPLOADED
  QUEUED_FOR_PRINT
  PRINTED
  DISPATCHED
  IN_TRANSIT
  DELIVERED
  RETURN_REQUESTED
  RETURN_IN_TRANSIT
  RETURNED
}

enum ShipmentDirection {
  OUTBOUND
  RETURN
}

enum SubmissionStatus {
  PENDING_RATES
  PENDING_SUBMISSION
  SUCCESS
  NO_RATES
  FAILED_WILL_RETRY
  FAILED_INDEFINITELY
}

enum PaymentStatus {
  UNPAID
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum ReturnPreference {
  DIRECT
  MANAGED
}

enum FeaturePriority {
  HIGH
  MEDIUM
  LOW
}

enum FeatureStatus {
  NOT_STARTED
  IN_PROGRESS
  READY
  IMPLEMENTED
}

// EPSON is the OAuth-based Epson Connect cloud API (src/lib/epson.ts).
// EPSON_DIRECT is Epson's "Email Print" feature - printing by emailing a
// PDF straight to the printer's own assigned address, with no OAuth app
// registration required at all.
enum PrintProvider {
  EPSON
  EPSON_DIRECT
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  role          Role      @default(CUSTOMER)
  consentedAt   DateTime?
  createdAt     DateTime  @default(now())

  documents     Document[]
  auditEvents   AuditEvent[]
}

model Document {
  id               String         @id @default(cuid())
  ownerId          String
  owner            User           @relation(fields: [ownerId], references: [id])
  status           DocumentStatus @default(UPLOADED)
  storageKey       String
  checksum         String
  encryptionKeyRef String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // Delivery address for this document. One address per document keeps this
  // simple; a customer with multiple documents can have different addresses
  // on each rather than needing a shared address book.
  recipientName    String
  recipientPhone   String
  recipientEmail   String
  streetAddress    String
  localArea        String
  city             String
  zone             String
  postalCode       String
  country          String         @default("ZA")

  // Option A (Direct) vs Option B (Fully Managed) from the return pathway
  // the customer chose at submission time.
  returnPreference ReturnPreference @default(MANAGED)

  // Print preferences chosen by the customer at dispatch (honoured by
  // Epson Connect Print EpsonAPI; staff can override in the print dialog).
  // colorMode: mono | color. copies: 1–10.
  printColorMode   String         @default("mono")
  printCopies      Int            @default(1)

  // Courier rate charged for the outbound dispatch, set once a shipment is
  // booked (src/lib/dispatch.ts). The dispatch fee payment is created from
  // this amount, not recomputed at payment time.
  dispatchFee      Float?

  auditEvents      AuditEvent[]
  bobgoShipments   BobgoShipment[]
  payments         Payment[]
  epsonPrintJobs   EpsonPrintJob[]
}

// Append-only chain-of-custody log. Rows are never updated or deleted from
// application code; `prevHash`/`hash` form a tamper-evident chain.
model AuditEvent {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id])
  actorId     String?
  actor       User?    @relation(fields: [actorId], references: [id])
  action      String
  metadata    Json?
  ip          String?
  prevHash    String?
  hash        String
  createdAt   DateTime @default(now())

  @@index([documentId])
}

// One row per courier shipment attempt on a document — an OUTBOUND dispatch
// and, later, a RETURN each get their own row so both legs of the
// chain-of-custody are independently trackable.
model BobgoShipment {
  id                String            @id @default(cuid())
  documentId        String
  document          Document          @relation(fields: [documentId], references: [id])
  direction         ShipmentDirection
  bobgoOrderId      Int?
  providerSlug      String?
  serviceLevelCode  String?
  trackingReference String?           @unique
  submissionStatus  SubmissionStatus  @default(PENDING_RATES)
  trackingStatus    String?
  failedReason      String?
  waybillUrl        String?
  podUrl            String?
  rawPayload        Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([documentId])
}

// Internal staff-only feature/roadmap tracker - not part of the customer-
// facing product or the chain-of-custody audit trail, just a lightweight
// planning tool.
model Feature {
  id        String          @id @default(cuid())
  name      String
  priority  FeaturePriority @default(MEDIUM)
  status    FeatureStatus   @default(NOT_STARTED)
  comment   String?
  checked   Boolean         @default(false)
  createdBy String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

// Epson's API has no "list all jobs" endpoint, only lookup by ID - this
// records every job we create so status.ts can poll each one individually
// to build a pending-jobs count instead of asking Epson for a list.
model EpsonPrintJob {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id])
  jobId      String   @unique
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([documentId])
}

// Singleton row (id is always the fixed string "singleton") holding the
// staff-configurable choice of which print backend the print queue's
// "Print (API)" button uses, plus the destination address for EPSON_DIRECT,
// and (when Epson Connect OAuth has succeeded) the shared device tokens.
// Read/written via /api/print-settings and src/lib/epson.ts.
model PrintSettings {
  id                  String        @id @default("singleton")
  provider            PrintProvider @default(EPSON)
  epsonDirectEmail    String?
  // Device tokens from OAuth authorization_code / refresh — server-side so
  // any staff browser and any serverless invocation can print/status-check.
  epsonAccessToken    String?
  epsonRefreshToken   String?
  epsonTokenExpiresAt DateTime?
  // Facility default job settings (manual adjusters on Printer Hub).
  // Customer-chosen color/copies live on Document; staff may override at print.
  printPaperSize      String        @default("ps_a4")
  printPaperType      String        @default("pt_plainpaper")
  printQuality        String        @default("normal")
  printPaperSource    String        @default("rear")
  printBorderless     Boolean       @default(false)
  printDoubleSided    String        @default("none")
  updatedAt           DateTime      @updatedAt
}

// A Bob Pay payment intent for a document's dispatch fee.
model Payment {
  id              String        @id @default(cuid())
  documentId      String
  document        Document      @relation(fields: [documentId], references: [id])
  customPaymentId String        @unique
  bobpayUuid      String?
  amount          Float
  status          PaymentStatus @default(UNPAID)
  paymentMethod   String?
  paymentUrl      String?
  rawPayload      Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([documentId])
}
