generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  STAFF
  ADMIN
}

enum DocumentStatus {
  UPLOADED
  QUEUED_FOR_PRINT
  PRINTED
  DISPATCHED
  IN_TRANSIT
  DELIVERED
  RETURN_REQUESTED
  RETURN_IN_TRANSIT
  RETURNED
}

enum ShipmentDirection {
  OUTBOUND
  RETURN
}

enum SubmissionStatus {
  PENDING_RATES
  PENDING_SUBMISSION
  SUCCESS
  NO_RATES
  FAILED_WILL_RETRY
  FAILED_INDEFINITELY
}

enum PaymentStatus {
  UNPAID
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum ReturnPreference {
  DIRECT
  MANAGED
}

enum FeaturePriority {
  HIGH
  MEDIUM
  LOW
}

enum FeatureStatus {
  NOT_STARTED
  IN_PROGRESS
  READY
  IMPLEMENTED
}

enum PrintProvider {
  EPSON
  LINUX_AGENT
}

enum LinuxPrintJobStatus {
  PENDING
  PRINTED
  FAILED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  role          Role      @default(CUSTOMER)
  consentedAt   DateTime?
  createdAt     DateTime  @default(now())

  documents     Document[]
  auditEvents   AuditEvent[]
}

model Document {
  id               String         @id @default(cuid())
  ownerId          String
  owner            User           @relation(fields: [ownerId], references: [id])
  status           DocumentStatus @default(UPLOADED)
  storageKey       String
  checksum         String
  encryptionKeyRef String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // Delivery address for this document. One address per document keeps this
  // simple; a customer with multiple documents can have different addresses
  // on each rather than needing a shared address book.
  recipientName    String
  recipientPhone   String
  recipientEmail   String
  streetAddress    String
  localArea        String
  city             String
  zone             String
  postalCode       String
  country          String         @default("ZA")

  // Option A (Direct) vs Option B (Fully Managed) from the return pathway
  // the customer chose at submission time.
  returnPreference ReturnPreference @default(MANAGED)

  // Courier rate charged for the outbound dispatch, set once a shipment is
  // booked (src/lib/dispatch.ts). The dispatch fee payment is created from
  // this amount, not recomputed at payment time.
  dispatchFee      Float?

  auditEvents      AuditEvent[]
  bobgoShipments   BobgoShipment[]
  payments         Payment[]
  epsonPrintJobs   EpsonPrintJob[]
  linuxPrintJobs   LinuxPrintJob[]
}

// Append-only chain-of-custody log. Rows are never updated or deleted from
// application code; `prevHash`/`hash` form a tamper-evident chain.
model AuditEvent {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id])
  actorId     String?
  actor       User?    @relation(fields: [actorId], references: [id])
  action      String
  metadata    Json?
  ip          String?
  prevHash    String?
  hash        String
  createdAt   DateTime @default(now())

  @@index([documentId])
}

// One row per courier shipment attempt on a document — an OUTBOUND dispatch
// and, later, a RETURN each get their own row so both legs of the
// chain-of-custody are independently trackable.
model BobgoShipment {
  id                String            @id @default(cuid())
  documentId        String
  document          Document          @relation(fields: [documentId], references: [id])
  direction         ShipmentDirection
  bobgoOrderId      Int?
  providerSlug      String?
  serviceLevelCode  String?
  trackingReference String?           @unique
  submissionStatus  SubmissionStatus  @default(PENDING_RATES)
  trackingStatus    String?
  failedReason      String?
  waybillUrl        String?
  podUrl            String?
  rawPayload        Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([documentId])
}

// Internal staff-only feature/roadmap tracker - not part of the customer-
// facing product or the chain-of-custody audit trail, just a lightweight
// planning tool.
model Feature {
  id        String          @id @default(cuid())
  name      String
  priority  FeaturePriority @default(MEDIUM)
  status    FeatureStatus   @default(NOT_STARTED)
  comment   String?
  checked   Boolean         @default(false)
  createdBy String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

// Epson's API has no "list all jobs" endpoint, only lookup by ID - this
// records every job we create so status.ts can poll each one individually
// to build a pending-jobs count instead of asking Epson for a list.
model EpsonPrintJob {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id])
  jobId      String   @unique
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([documentId])
}

// Singleton row (id is always the fixed string "singleton") holding the
// staff-configurable choice of which print backend the print queue's
// "Print (API)" button uses. Read/written via /api/print-settings.
model PrintSettings {
  id        String        @id @default("singleton")
  provider  PrintProvider @default(EPSON)
  updatedAt DateTime      @updatedAt
}

// A job queued for the Linux print agent - a pull-based unattended script
// (see agent/linux-print-agent.py) running on a machine with a physically
// connected printer. The agent polls for PENDING jobs, downloads the file,
// prints via CUPS, then reports success/failure through a static bearer
// token (PRINT_AGENT_TOKEN) rather than a browser session, since there's
// no user logged in on that machine.
model LinuxPrintJob {
  id         String              @id @default(cuid())
  documentId String
  document   Document            @relation(fields: [documentId], references: [id])
  status     LinuxPrintJobStatus @default(PENDING)
  error      String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([documentId])
  @@index([status])
}

// A Bob Pay payment intent for a document's dispatch fee.
model Payment {
  id              String        @id @default(cuid())
  documentId      String
  document        Document      @relation(fields: [documentId], references: [id])
  customPaymentId String        @unique
  bobpayUuid      String?
  amount          Float
  status          PaymentStatus @default(UNPAID)
  paymentMethod   String?
  paymentUrl      String?
  rawPayload      Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([documentId])
}
